{
  "uid": "kiosk-fleet-overview",
  "title": "Kiosk Fleet — Overview",
  "tags": [
    "kiosk",
    "lfac"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "editable": true,
  "refresh": "1m",
  "links": [
    {
      "type": "dashboards",
      "title": "Kiosk dashboards",
      "tags": [
        "kiosk"
      ],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false
    },
    {
      "type": "link",
      "title": "Visual Timeline",
      "url": "https://kiosk-timeline.xzibitapps.workers.dev/app?k=d6210121f591954d5bf4b28376e3e15576e5702f540f6117",
      "icon": "external link",
      "targetBlank": true,
      "keepTime": true,
      "includeVars": false,
      "tooltip": "Scrub-able screenshot timeline for the fleet (opens with this dashboard's time range)"
    }
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Kiosk",
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        },
        "definition": "label_values(kiosk_agent_info, instance)",
        "query": {
          "query": "label_values(kiosk_agent_info, instance)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kiosks reporting",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count(kiosk_agent_info{instance=~\"$instance\"})",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Hosts reconcile-stale (>25h)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count((time() - kiosk_agent_reconcile_last_success_timestamp_seconds{instance=~\"$instance\"}) > 90000) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "description": "Reconcile hasn't succeeded in >25h (daily task is 03:30)."
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Hosts with stale components",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count(max by (instance) (kiosk_agent_component_drift{instance=~\"$instance\"}) > 0) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "description": "Installed component version != desired for its channel."
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hosts with errored components",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count(count by (instance) (kiosk_agent_component_up{instance=~\"$instance\"} == 0)) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Apps down (hosts)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count(max by (instance) (kiosk_app_expected{instance=~\"$instance\"} - kiosk_app_up{instance=~\"$instance\"}) > 0) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Kiosks not in kiosk-mode",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count(max by (instance) (kiosk_mode{instance=~\"$instance\"}) == 0) or vector(0)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "description": "Reporting kiosk_mode=0 (out of Shell Launcher kiosk mode)."
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Worst clock drift",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "max(abs(windows_time_current_timestamp_seconds{instance=~\"$instance\"} - time()))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 120
              },
              {
                "color": "red",
                "value": 300
              }
            ]
          },
          "description": "Approx; dominated by scrape age (<~90s) unless genuinely skewed."
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Max temperature",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "max(windows_thermalzone_temperature_celsius{instance=~\"$instance\"})",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 85
              }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Hosts with each component stale",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "count by (component) (kiosk_agent_component_drift{instance=~\"$instance\"} > 0)",
          "instant": true,
          "legendFormat": "{{component}}"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "orange",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "description": "Per-component count of hosts whose installed version != desired."
        }
      }
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Max CPU busy %",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "max(100 - (avg by (instance) (rate(windows_cpu_time_total{mode=\"idle\", instance=~\"$instance\"}[5m])) * 100))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Max memory used %",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "max(100 * (1 - avg by (instance) (windows_memory_available_bytes{instance=~\"$instance\"}) / avg by (instance) (windows_memory_physical_total_bytes{instance=~\"$instance\"})))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 90
              },
              {
                "color": "red",
                "value": 95
              }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "type": "stat",
      "title": "Min disk free % (C:)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "min(avg by (instance) (windows_logical_disk_free_bytes{volume=\"C:\", instance=~\"$instance\"}) / avg by (instance) (windows_logical_disk_size_bytes{volume=\"C:\", instance=~\"$instance\"}) * 100)",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 10
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "green",
                "value": 20
              }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "type": "stat",
      "title": "Fleet CPU max (trend)",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-prom"
      },
      "targets": [
        {
          "refId": "A",
          "editorMode": "code",
          "expr": "max(100 - (avg by (instance) (rate(windows_cpu_time_total{mode=\"idle\", instance=~\"$instance\"}[5m])) * 100))",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "none",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent"
        }
      }
    }
  ]
}
