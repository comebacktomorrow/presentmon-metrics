{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "expr": "kiosk_app_start_time_seconds{instance=~\"$instance\"} > $__from < $__to",
        "hide": false,
        "iconColor": "light-blue",
        "name": "App restart",
        "tagKeys": "instance,site,location",
        "textFormat": "{{instance}} restarted",
        "titleFormat": "App restart",
        "useValueForTime": true
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "enable": true,
        "expr": "ALERTS{alertname=\"KioskAppFrozen\", instance=~\"$instance\"}",
        "hide": false,
        "iconColor": "red",
        "name": "Freeze (KioskAppFrozen)",
        "step": "10s",
        "tagKeys": "instance,site,location,alertstate",
        "textFormat": "{{instance}} frozen",
        "titleFormat": "App frozen"
      },
      {
        "name": "App crashes",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "expr": "{job=\"kiosk-logs\"} |= \"app exited unexpectedly\"",
        "tagKeys": "host"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "liveNow": false,
  "panels": [
    {
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
