        "annotationLanes": "shared",
        "apiKey": "",
        "apiUrl": "http://localhost:8787",
        "followCrosshair": true,
        "headerMode": "bar",
        "hideEmpty": true,
        "imageFit": "fit",
        "mode": "timeline",
        "showAnnotations": true,
        "showDetails": false,
        "sites": "${site:csv}",
        "tagFilter": ""
      },
      "pluginVersion": "0.9.6",
      "targets": [
        {
          "refId": "A"
        }
      ],
      "title": "$location screen — hover to scrub, correlate against the graphs below",
      "type": "xzibit-kiosktimeline-panel"
