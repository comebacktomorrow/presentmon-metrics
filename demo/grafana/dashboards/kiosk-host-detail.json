    {
      "type": "link",
      "title": "Visual Timeline",
      "url": "https://kiosk-timeline.xzibitapps.workers.dev/app?k=d6210121f591954d5bf4b28376e3e15576e5702f540f6117",
      "icon": "external link",
      "targetBlank": true,
      "keepTime": true,
      "includeVars": false,
      "tooltip": "Scrub-able screenshot timeline for the fleet (opens with this dashboard's time range)"
