  "editable": true,
  "refresh": "1m",
  "links": [
    {
      "type": "dashboards",
      "title": "Kiosk dashboards",
      "tags": [
        "kiosk"
      ],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link",
      "targetBlank": false
