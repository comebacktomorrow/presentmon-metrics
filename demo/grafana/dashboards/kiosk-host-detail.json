  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "label": "Kiosk",
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-prom"
        },
        "definition": "label_values(kiosk_agent_info, instance)",
        "query": {
          "query": "label_values(kiosk_agent_info, instance)",
          "refId": "StandardVariableQuery"
        },
        "includeAll": false,
        "multi": false,
        "current": {
          "text": "LFSC-MPC2-1-1",
          "value": "LFSC-MPC2-1-1"
        },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Host",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
